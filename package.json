{
  "name": "apple-notes-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for Apple Notes with a local vector database for semantic search, plus fuzzy title, tag, date, and metadata search.",
  "type": "module",
  "license": "MIT",
  "author": "Jonathan Backhaus",
  "bin": {
    "apple-notes-mcp": "dist/src/index.js"
  },
  "files": [
    "dist/src",
    "README.md"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/src/index.js",
    "reindex": "node dist/src/index.js reindex",
    "test": "npm run build && node --test \"dist/test/**/*.test.js\"",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "fuse.js": "^7.0.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.6.0"
  }
}
